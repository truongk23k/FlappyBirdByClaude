/* ==========================================================================
   List View Styles - List containers and item styles
   ========================================================================== */

/* Base List View */
.mcp-list-view {
    flex-grow: 1;
    padding-left: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-top: 0;
}

.mcp-list-view .unity-list-view__item:hover {
    background-color: rgba(0, 0, 0, 0);
}

.mcp-list-view .unity-scroll-view__content-container {
    padding-left: 15px;
    padding-right: 15px;
    padding-top: 20px;
    padding-bottom: 20px;
}

/* Item Container */
.item-container {
    background-color: var(--unity-colors-helpbox-background);
    border-radius: 12px;
    padding: 10px;
    margin-bottom: 7px;
}

/* Item Header */
.item-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
}

/* Item Title Container */
.item-title-container {
    flex-grow: 1;
    margin-right: 10px;
}

/* Item Title */
.item-title {
    font-size: 16px;
    -unity-font-style: bold;
    white-space: normal;
    flex-grow: 1;
    flex-shrink: 1;
    margin-right: 10px;
}

/* Item ID/Subtitle */
.item-id {
    font-size: 12px;
    color: var(--unity-colors-helpbox-text);
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Item Highlighting States — semitransparent tints layer over the
   theme-aware base so the card stays readable on both light and dark
   editor skins. */
.item-container.enabled {
    background-color: rgba(80, 160, 80, 0.18);
    transition-duration: 200ms;
}

.item-container.disabled {
    background-color: rgba(160, 80, 80, 0.18);
    transition-duration: 200ms;
}
